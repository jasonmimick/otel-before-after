{
  "uid": "oba-social",
  "title": "otel-before-after · social",
  "tags": ["otel-before-after"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## social — after (instrumented) vs before (zero OTel)\nEverything below comes from **social-after**. The identical app **social-before** receives the same traffic and appears in *none* of these panels — search Tempo/Loki/Prometheus for `social-before` and you'll find nothing. That gap is what instrumentation buys. · [repo](https://github.com/jasonmimick/otel-before-after)"
      }
    },
    {
      "type": "stat",
      "title": "Requests/s (after)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"social-after\"}[5m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Posts created (30m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(post_created_total{service_name=\"social-after\"}[30m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Business events/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 3 },
      "targets": [
        { "refId": "A", "legendFormat": "user.created", "expr": "sum(rate(user_created_total{service_name=\"social-after\"}[5m]))" },
        { "refId": "B", "legendFormat": "post.created", "expr": "sum(rate(post_created_total{service_name=\"social-after\"}[5m]))" },
        { "refId": "C", "legendFormat": "feed.fetched", "expr": "sum(rate(feed_fetched_total{service_name=\"social-after\"}[5m]))" },
        { "refId": "D", "legendFormat": "users.list", "expr": "sum(rate(users_list_total{service_name=\"social-after\"}[5m]))" },
        { "refId": "E", "legendFormat": "posts.list", "expr": "sum(rate(posts_list_total{service_name=\"social-after\"}[5m]))" },
        { "refId": "F", "legendFormat": "notification.sent", "expr": "sum(rate(notification_sent_total{service_name=\"social-after\"}[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HTTP latency (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 3 },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"social-after\"}[5m])))" },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"social-after\"}[5m])))" },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"social-after\"}[5m])))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Users created (30m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(user_created_total{service_name=\"social-after\"}[30m])) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Notifications sent (30m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(notification_sent_total{service_name=\"social-after\"}[30m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "logs",
      "title": "Business events (Loki, trace-correlated)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "targets": [
        { "refId": "A", "expr": "{service_name=\"social-after\"}" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "type": "table",
      "title": "Recent traces (Tempo) — click a trace ID",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"social-after\"}",
          "limit": 20
        }
      ]
    }
  ]
}
