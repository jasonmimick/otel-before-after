{
  "uid": "oba-ecommerce",
  "title": "otel-before-after · ecommerce",
  "tags": ["otel-before-after"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## ecommerce — after (instrumented) vs before (zero OTel)\nEverything below comes from **ecommerce-after**. The identical app **ecommerce-before** receives the same traffic and appears in *none* of these panels — search Tempo/Loki/Prometheus for `ecommerce-before` and you'll find nothing. That gap is what instrumentation buys. · [repo](https://github.com/jasonmimick/otel-before-after)"
      }
    },
    {
      "type": "stat",
      "title": "Requests/s (after)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"ecommerce-after\"}[5m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Orders created (30m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(orders_created_total{service_name=\"ecommerce-after\"}[30m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Business events/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 3 },
      "targets": [
        { "refId": "A", "legendFormat": "checkout.attempts", "expr": "sum(rate(checkout_attempts_total{service_name=\"ecommerce-after\"}[5m]))" },
        { "refId": "B", "legendFormat": "orders.created", "expr": "sum(rate(orders_created_total{service_name=\"ecommerce-after\"}[5m]))" },
        { "refId": "C", "legendFormat": "cart.updates", "expr": "sum(rate(cart_updates_total{service_name=\"ecommerce-after\"}[5m]))" },
        { "refId": "D", "legendFormat": "checkout.fraud_declines", "expr": "sum(rate(checkout_fraud_declines_total{service_name=\"ecommerce-after\"}[5m]))" },
        { "refId": "E", "legendFormat": "payment.failures", "expr": "sum(rate(payment_failures_total{service_name=\"ecommerce-after\"}[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HTTP latency (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 3 },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"ecommerce-after\"}[5m])))" },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"ecommerce-after\"}[5m])))" },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=\"ecommerce-after\"}[5m])))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Cart updates (30m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(cart_updates_total{service_name=\"ecommerce-after\"}[30m])) or vector(0)" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Avg checkout value (USD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(checkout_value_usd_sum{service_name=\"ecommerce-after\"}[30m])) / sum(rate(checkout_value_usd_count{service_name=\"ecommerce-after\"}[30m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] }
    },
    {
      "type": "logs",
      "title": "Business events (Loki, trace-correlated)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "targets": [
        { "refId": "A", "expr": "{service_name=\"ecommerce-after\"}" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "type": "table",
      "title": "Recent traces (Tempo) — click a trace ID",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"ecommerce-after\"}",
          "limit": 20
        }
      ]
    }
  ]
}
